{
  "manifest_version": 3,
  "name": "Kialo Assistant",
  "version": "1.0.0",
  "key": "",
  "action": { "default_title": "Open Sidepanel" },
  "permissions": ["sidePanel", "identity", "storage"],
  "host_permissions": ["https://www.kialo.com/*", "http://localhost:8082/*", "http://localhost:1234/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}